<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Argos.MainWindow"
        Title="Argos v0.1"
        Background="#0D1117"
        Foreground="#C9D1D9">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Margin="20">

    <TextBlock x:Name="RelogioTexto"
                Text="00:00:00"
                FontSize="32"
                FontWeight="Bold"
                Foreground="#33FF00"
                HorizontalAlignment="Center"
                Margin="0,0,0,10"/>
                
    <TextBlock Text="Minhas Tarefas" FontSize="20" HorizontalAlignment="Center"/>

    <TextBox x:Name="CaixaDeTexto"
               Watermark="O que precisa ser feito?"
               KeyDown="AoApertarTeclaNaCaixa"
               Width="600"/>           

    <Button Content="Adicionar"
            Click="AoClicarNoBotao"
            HorizontalAlignment="Center"/>

    <ScrollViewer MaxHeight="400" Width="600">
    
    <StackPanel x:Name="ListaDeTarefas" Spacing="10">
    </StackPanel>
    </ScrollViewer>

    <Button Content="Limpar Tarefas Concluídas"
                Click="AoClicarEmLimpar"
                HorizontalAlignment="Center"
                Background="#FFdddd"
                Foreground="Red"/>
            </StackPanel>

</Window>
